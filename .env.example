# Copy to .env for production (compose reads it). NEVER commit real secrets.

# --- Postgres ---
# URL-SAFE password only. Do NOT use `openssl rand -base64` here — its / + =
# characters break the postgres:// connection URL. Generate with:
#   openssl rand -hex 24
POSTGRES_PASSWORD=

# DATABASE_URL / DB_OWNER_URL are built automatically by compose from
# POSTGRES_PASSWORD (host `db`). Leave them UNSET here. Only set them if you run
# the app OUTSIDE compose against your own Postgres:
# DATABASE_URL=postgres://user:pass@host:5432/token_system

# --- Secrets ---
# SESSION_SECRET is REQUIRED in production (>=16 chars) — the app refuses to start
# without it (signs the counter-login gate). Generate with: openssl rand -base64 32
SESSION_SECRET=
# Pin so redeploys don't invalidate in-flight Server Action payloads (recommended):
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# --- First admin (seeded once; you may remove SEED_ADMIN_PASSWORD afterwards) ---
# STRENGTH-ENFORCED: >= 12 characters, with an uppercase, a lowercase, and a digit.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=

# --- Cloudflare Tunnel (production) ---
TUNNEL_TOKEN=

# --- Misc ---
TZ=Asia/Kolkata
