# Copy to .env for local dev, or provide via Docker/compose in prod. NEVER commit real secrets.

# --- Postgres (compose sets these for local dev) ---
POSTGRES_PASSWORD=postgres
# App runtime connection (least-privilege role in prod). Local dev via compose:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/token_system
# Migrations connection (owner role; may equal DATABASE_URL in dev):
DB_OWNER_URL=postgres://postgres:postgres@localhost:5432/token_system

# --- Secrets (generate with: openssl rand -base64 32) ---
# SESSION_SECRET is REQUIRED in production (>=16 chars) — the app refuses to start
# without it (signs the counter-login gate). See src/lib/env.ts.
SESSION_SECRET=
DISPLAY_LINK_SECRET=
# Pin so redeploys don't invalidate in-flight Server Action payloads (recommended in prod):
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# --- First admin (seeded once by scripts/seed-admin.ts, then remove) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=

# --- Cloudflare Tunnel (production only) ---
TUNNEL_TOKEN=

# --- Misc ---
TZ=Asia/Kolkata
NODE_ENV=development
